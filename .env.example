# ─── Sentinel Earn — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values.
# Only GITHUB_TOKEN and GITHUB_USERNAME are required for live PR submission.
# Everything else has working defaults.

# ─── GitHub Credentials ───────────────────────────────────────────────────────
# Generate a fine-grained PAT at: https://github.com/settings/tokens?type=beta
# Required permissions:
#   Repository access: All repositories (or specific repos)
#   Permissions: Contents (write), Issues (write), Pull Requests (write)
GITHUB_TOKEN=ghp_your_github_personal_access_token_here
GITHUB_USERNAME=your_github_username

# ─── Agent Behaviour ──────────────────────────────────────────────────────────
# Set to true for a completely safe test run (no GitHub writes, no file changes)
DRY_RUN=false

# How often to scan for new opportunities (hours)
SCAN_INTERVAL_HOURS=2

# ─── Ollama (Local AI — zero paid APIs) ───────────────────────────────────────
# Ollama must be running locally before starting Sentinel Earn.
# Install: https://ollama.com
# Pull model: ollama pull qwen2.5-coder:14b
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:14b

# ─── SentinelAI Authentication ────────────────────────────────────────────────
# Token for remote API access (phone control, approvals, etc.)
# Generate a secure random token: python -c "import secrets; print(secrets.token_urlsafe(32))"
SENTINELAI_AUTH_TOKEN=your_secure_random_token_here

# ─── Phase 7: Always-On Operations ────────────────────────────────────────────
# Worker Management
MAX_WORKERS=3
MAX_BROWSER_SESSIONS=3
MAX_AI_REQUESTS=2

# Queue Management
MAX_QUEUE_SIZE=500
TASK_TIMEOUT_MINUTES=30

# Health Monitoring
HEALTH_CHECK_INTERVAL=60
WATCHDOG_CHECK_INTERVAL=30

# Cleanup
CLEANUP_OLD_TASKS_DAYS=30
CLEANUP_TEMP_FILES_DAYS=7

# ─── Orchestration Intelligence ─────────────────────────────────────────────
# Optional provider keys. Leave blank for local/offline-safe fallbacks.
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
SERPER_API_KEY=

# Optional model routing.
OLLAMA_SMALL_MODEL=llama3.2:1b
FRONTIER_PROVIDER=disabled
FRONTIER_MODEL=

# Vector memory backend. sqlite is default; chroma is optional.
VECTOR_STORE_BACKEND=sqlite

# ─── Track 8: Wake Word Detection ───────────────────────────────────────────
WAKE_WORD_ENABLED=false

# ─── Track 9: Messaging Bridge ─────────────────────────────────────────────
# Telegram Bot Setup: https://core.telegram.org/bots#creating-a-new-bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USER_ID=your_telegram_user_id_here
# Find your user ID by messaging @userinfobot on Telegram

# WhatsApp (experimental - may be unstable)
WHATSAPP_ALLOWED_NUMBER=+1XXXXXXXXXX

# ─── Track 10: Home Assistant & Smart Home ─────────────────────────────────
# Home Assistant long-lived access token
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token_here

# Direct camera integrations (fallback if HA not configured)
BLINK_EMAIL=your_blink_email
BLINK_PASSWORD=your_blink_password
EUFY_EMAIL=your_eufy_email
EUFY_PASSWORD=your_eufy_password
ARLO_EMAIL=your_arlo_email
ARLO_PASSWORD=your_arlo_password

# ─── Track 11: Proactive Agents ────────────────────────────────────────────
PROACTIVE_ENABLED=true
MORNING_BRIEFING_TIME=07:00
# Coordinates for weather (default: San Jose, CA)
LATITUDE=37.3382
LONGITUDE=-121.8863

# ─── Track 12: Health & Wearables ──────────────────────────────────────────
# Open Wearables API token
OPEN_WEARABLES_TOKEN=your_open_wearables_token_here

# ─── Track 13: Finance (Firefly III) ───────────────────────────────────────
# Self-hosted Firefly III personal finance
FIREFLY_URL=http://localhost:8080
FIREFLY_TOKEN=your_firefly_personal_access_token

# ─── Track 14: Music Control (Spotify) ─────────────────────────────────────
# Spotify Developer App: https://developer.spotify.com/dashboard/applications
SPOTIPY_CLIENT_ID=your_spotify_client_id
SPOTIPY_CLIENT_SECRET=your_spotify_client_secret
SPOTIPY_REDIRECT_URI=http://localhost:8888/callback

# ─── Track 15: Package Tracking ────────────────────────────────────────────
# USPS Web Tools API: https://www.usps.com/business/web-tools-apis/
USPS_USER_ID=your_usps_user_id

# ─── Track 16: News Feed (Miniflux) ────────────────────────────────────────
# Self-hosted Miniflux RSS reader
MINIFLUX_URL=http://localhost:8085
MINIFLUX_API_KEY=your_miniflux_api_key

# ─── OpenClaw: Web Search ──────────────────────────────────────────────────
# Brave Search API: https://brave.com/search/api/
BRAVE_API_KEY=your_brave_search_api_key_here
